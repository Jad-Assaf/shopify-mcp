SHOPIFY_SHOP_DOMAIN=example.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=replace-with-shopify-admin-api-token
SHOPIFY_API_VERSION=2026-04
MCP_API_KEY=replace-with-random-mcp-api-key
ALLOW_WRITE_TOOLS=false

# Optional comma-separated browser origins allowed to call /mcp when an Origin header is present.
# Leave empty for non-browser MCP clients and same-origin requests.
MCP_ALLOWED_ORIGINS=

# Optional Shopify client tuning.
SHOPIFY_REQUEST_TIMEOUT_MS=20000
SHOPIFY_MAX_RETRIES=2
